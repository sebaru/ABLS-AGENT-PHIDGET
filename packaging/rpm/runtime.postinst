#!/bin/sh
set -eu

if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
  systemctl daemon-reload >/dev/null 2>&1 || true

  active_units="$(systemctl list-units --type=service --state=active 'abls-agent-phidget@*.service' --no-legend --no-pager 2>/dev/null | awk '{print $1}')"
  if [ -n "$active_units" ]; then
    for unit in $active_units; do
      systemctl try-restart "$unit" >/dev/null 2>&1 || true
    done
  fi
fi

exit 0
